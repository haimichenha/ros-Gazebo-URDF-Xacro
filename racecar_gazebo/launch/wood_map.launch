<!-- 文件名: slam_world.launch (最终无错版 - 砖墙世界导航) -->
<launch>
    <param name="/use_sim_time" value="true"/>

    <!-- 阶段一：启动砖墙世界 -->
    <include file="$(find racecar_gazebo)/launch/racecar.launch">
        <arg name="world_name" value="$(find racecar_gazebo)/worlds/wood_map.world"/>     <!-- 1 -->
        <arg name="x_pos" value="0.0"/>
        <arg name="y_pos" value="0.0"/>
    </include>

    <!-- 阶段二：延迟启动导航组件 -->                                        <!-- 2 -->

    <node name="map_server" pkg="map_server" type="map_server" 
          args="$(find racecar_gazebo)/maps/wood_map.yaml"         
          launch-prefix="bash -c 'sleep 3.0; $0 $@'"/>

    <node pkg="amcl" type="amcl" name="amcl"
          launch-prefix="bash -c 'sleep 4.0; $0 $@'">
        <!-- 复制 amcl.xml 的核心参数，但不加 initial_pose，因为需要手动定位 -->
        <param name="use_map_topic" value="true"/>
        <param name="odom_model_type" value="diff"/>
        <param name="odom_frame_id" value="odom"/>
        <param name="base_frame_id" value="base_footprint"/>
        <param name="global_frame_id" value="map"/>
        <param name="min_particles" value="500"/>
        <param name="max_particles" value="2000"/>
        <param name="update_min_d" value="0.2"/>
        <param name="update_min_a" value="0.5"/>
    </node>

    <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen"
          launch-prefix="bash -c 'sleep 5.0; $0 $@'">
        <!-- 完整保留所有原始 move_base 参数 -->
        <rosparam file="$(find racecar_gazebo)/config/navigation/costmap_common_params.yaml" command="load" ns="global_costmap" />
        <rosparam file="$(find racecar_gazebo)/config/navigation/costmap_common_params.yaml" command="load" ns="local_costmap" />
        <rosparam file="$(find racecar_gazebo)/config/navigation/local_costmap_params.yaml" command="load" />
        <rosparam file="$(find racecar_gazebo)/config/navigation/global_costmap_params.yaml" command="load" />
        
        <rosparam file="$(find racecar_gazebo)/config/navigation/dwa_local_planner_params.yaml" command="load" />
        <!-- <rosparam file="$(find racecar_gazebo)/config/navigation/teb_local_planner_params.yaml" command="load" /> -->

        <param name="controller_patience" value="15.0" />
        <param name="planner_patience" value="10.0" />
        <param name="base_global_planner" value="navfn/NavfnROS" />
        <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS" />
        <param name="planner_frequency" value="10.0" />
        <param name="planner_patience" value="5.0" />
        <param name="controller_frequency" value="10.0" />
        <param name="controller_patience" value="15.0" />
        <param name="clearing_rotation_allowed" value="false" /> 
    </node>
    
    <node name="rviz" pkg="rviz" type="rviz"                                                
          args="-d $(find racecar_gazebo)/rviz/navigation.rviz" required="true"
          launch-prefix="bash -c 'sleep 5.0; $0 $@'"/>
    
    <node name="racecar_navigation" pkg="racecar_gazebo" type="racecar_navigation.py"
          launch-prefix="bash -c 'sleep 5.0; $0 $@'"/>
</launch>
