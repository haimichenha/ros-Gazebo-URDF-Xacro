<launch>

    <include file="$(find racecar_gazebo)/launch/hector1.launch"/>
    <include file="$(find racecar_gazebo)/launch/hector2.launch"/>

    <include file="$(find racecar_gazebo)/launch/racecar.launch"/>
  
    <!-- keyboard_remote node -->
    <node name="XL_keyboard_remote" pkg="racecar_gazebo" type="XL_keyboard_remote.py" output="screen">
    </node>

    <!-- 启动rviz -->
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find racecar_gazebo)/rviz/hector.rviz"/>

</launch>
